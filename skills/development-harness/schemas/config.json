{
  "schema_version": "1.0",
  "skill_version": "1.0",
  "_comment": "Example config.json illustrating the v2 execution_mode object. execution_mode is now a nested block with four sub-sections: location (runtime mode), parallelism (opt-in batch execution policy), agent_delegation (helper-agent preferences), versioning (back-compat stance on schema bumps). Defaults are chosen to be conservative: parallelism off, versioning breaks on schema bump.",
  "project": {
    "name": "my-app",
    "description": "A full-stack web application with API and frontend"
  },
  "stack": {
    "languages": ["typescript", "python"],
    "frameworks": ["react", "fastapi"],
    "package_manager": "pnpm",
    "runtime": "node20"
  },
  "deployment": {
    "target": "vercel",
    "url": "https://my-app.vercel.app",
    "environments": ["preview", "production"],
    "ci_cd": "github-actions",
    "verification_method": "smoke-test-url",
    "smoke_test_url": "https://my-app.vercel.app/api/health"
  },
  "git": {
    "default_branch": "main",
    "branch_convention": "feature/ISSUE-123-short-description",
    "commit_convention": "conventional-commits",
    "pr_size": "small",
    "merge_strategy": "squash",
    "review_policy": "ai-review"
  },
  "testing": {
    "e2e_framework": "playwright",
    "unit_framework": "vitest",
    "coverage_target": 80
  },
  "quality": {
    "definition_of_done": [
      "All tests pass",
      "No lint errors",
      "PR approved",
      "Documentation updated"
    ],
    "mandatory_checks": [
      "lint",
      "test",
      "build",
      "e2e-smoke"
    ]
  },
  "execution_mode": {
    "location": "local",
    "parallelism": {
      "enabled": false,
      "max_concurrent_units": 3,
      "conflict_strategy": "abort_batch",
      "require_touches_paths": true,
      "allow_cross_phase": false
    },
    "agent_delegation": {
      "use_explore_for_research": true,
      "use_code_review_skill_for_phase_review": true,
      "parallel_validation_layers": false
    },
    "versioning": {
      "break_on_schema_bump": true
    }
  }
}
