      "type": "config",
      "removable": true
    },
    {
      "path": ".harness/scripts/",
      "ownership": "harness-owned",
      "type": "directory",
      "removable": true
    },
    {
      "path": ".harness/plans/",
      "ownership": "harness-owned",
      "type": "directory",
      "removable": true
