      "ownership": "harness-owned",
      "type": "config",
      "removable": true
    },
    {
      "path": ".harness/manifest.json",
      "ownership": "harness-owned",
      "type": "manifest",
      "removable": true
    },
    {
      "path": ".harness/state.json",
      "ownership": "harness-owned",
      "type": "state",
      "removable": true
    },
    {
