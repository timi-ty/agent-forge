{
  "schema_version": "1.0",
  "skill_version": "1.0",
  "_comment": "Paths prefixed with $TOOL_DIR are parameterized. During create, substitute $TOOL_DIR with .cursor (Cursor) or .claude (Claude Code). $RULE_EXT is .mdc (Cursor) or .md (Claude Code). $HOOK_CONFIG ownership must be set to harness-owned for Cursor (.cursor/hooks.json) or managed-block for Claude Code (.claude/settings.local.json) since the latter is a shared file.",
  "entries": [
    {
      "path": "AGENTS.md",
      "ownership": "harness-owned",
      "type": "guidance",
      "removable": true,
      "note": "Created only if none existed; if pre-existing, ownership is managed-block instead"
    },
    {
      "path": ".harness/",
      "ownership": "harness-owned",
      "type": "directory",
      "removable": true
    },
    {
